@using Microsoft.Extensions.Options
@using HuTest.Models.Options
@inject IOptions<AuthOptions> AuthOpts
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · CEPLAN</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body data-inactividad-min="@AuthOpts.Value.Sesion.InactividadMinutos"
      data-aviso-seg="@AuthOpts.Value.Sesion.AvisoSegundos">
    <div class="ceplan-shell">
        <partial name="_Sidebar" />
        @* La preferencia del usuario (localStorage) manda sobre el estado que cada
           página trae por defecto, para que el modo contraído no se pierda al navegar.
           Si el usuario nunca tocó el toggle, se respeta el default de la vista
           (p. ej. Perfil llega contraído según Figma). Se aplica antes de pintar
           para que no haya parpadeo. *@
        <script>
            (function () {
                try {
                    var s = document.getElementById('ceplanSidebar');
                    if (!s || window.matchMedia('(max-width: 768px)').matches) return;
                    var pref = localStorage.getItem('ceplan-sidebar-collapsed');
                    if (pref === '1') s.classList.add('ceplan-sidebar--collapsed');
                    else if (pref === '0') s.classList.remove('ceplan-sidebar--collapsed');
                } catch (_) { }
            })();
        </script>
        <div class="ceplan-sidebar-backdrop" id="ceplanSidebarBackdrop" data-sidebar-close></div>
        <div class="ceplan-main">
            <partial name="_Header" />
            <main role="main" class="ceplan-content">
                @RenderBody()
            </main>
            <partial name="_Footer" />
        </div>
    </div>

    <partial name="_DialogoExpiracion" />
    <form id="formLogoutExpirado" method="post" asp-controller="Account" asp-action="LogoutExpirado" class="d-none"></form>
    <div class="ceplan-toast-zone">
        <partial name="_ToastSesion" />
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session-timeout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
