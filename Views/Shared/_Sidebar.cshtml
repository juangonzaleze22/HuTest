@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string ActivoCtrl(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var colapsado = ViewData["SidebarColapsado"] as bool? ?? false;
}
<aside class="ceplan-sidebar @(colapsado ? "ceplan-sidebar--collapsed" : "")" id="ceplanSidebar">
    <button type="button" class="ceplan-sidebar__toggle" data-sidebar-toggle aria-label="Contraer o expandir menú">
        <i class="bi bi-list"></i>
    </button>

    <span class="ceplan-sidebar__group-title">PEI Operador</span>

    <a class="ceplan-sidebar__link @ActivoCtrl("Home")" href="@Url.Action("Index", "Home")" title="Inicio">
        <i class="bi bi-house-door"></i> <span class="ceplan-sidebar__label">Inicio</span>
    </a>
    <a class="ceplan-sidebar__link" href="#" title="Gestión de usuarios">
        <i class="bi bi-building"></i> <span class="ceplan-sidebar__label">Gestión de usuarios</span>
    </a>
    <a class="ceplan-sidebar__link @ActivoCtrl("Perfil")" href="@Url.Action("Index", "Perfil")" title="Perfil de usuario">
        <i class="bi bi-file-earmark-person"></i> <span class="ceplan-sidebar__label">Perfil de usuario</span>
    </a>
    <a class="ceplan-sidebar__link" href="#" title="Buscar">
        <i class="bi bi-search"></i> <span class="ceplan-sidebar__label">Buscar</span>
    </a>
</aside>
