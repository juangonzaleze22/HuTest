# Plantilla de variables de entorno. Copia este archivo como ".env" y completa los valores.
#   cp .env.example .env   (o cópialo desde el explorador)
# Las variables usan el separador "__" que ASP.NET Core mapea a la jerarquía de configuración.

# --- Base de datos (sobrescribe ConnectionStrings:Default) ---
# Autenticación Windows (por defecto):
ConnectionStrings__Default=
# Autenticación SQL (ejemplo con credenciales — NO usar en el repo):
# ConnectionStrings__Default=Server=localhost;Database=HuTest;User Id=sa;Password=TU_PASSWORD;TrustServerCertificate=True

# --- SMTP ---
# Ejemplo para Gmail (requiere una "contraseña de aplicación", no la contraseña normal):
Smtp__Host=
Smtp__Port=
Smtp__From=
Smtp__Username=
Smtp__Password=
Smtp__Habilitado=
